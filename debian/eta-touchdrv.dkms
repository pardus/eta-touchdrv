PACKAGE_VERSION="__VERSION__"
PACKAGE_NAME="eta-touchdrv"
CLEAN="make -C touch2/kernel KVER=${kernelver} clean && make -C touch4/kernel KVER=${kernelver} clean"
MAKE="make -C touch2/kernel KVER=${kernelver} && make -C touch4/kernel KVER=${kernelver}"
BUILT_MODULE_NAME[0]="OpticalDrv2"
BUILT_MODULE_LOCATION[0]="touch2/kernel/"
DEST_MODULE_LOCATION[0]="/extra"
BUILT_MODULE_NAME[1]="OpticalDrv4"
BUILT_MODULE_LOCATION[1]="touch4/kernel/"
DEST_MODULE_LOCATION[1]="/extra"
AUTOINSTALL="yes"
