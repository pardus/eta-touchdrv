# MAKE and CLEAN are ugly but should work
# make -C somehow didn't work.
PACKAGE_VERSION="__VERSION__"
PACKAGE_NAME="eta-touchdrv"
CLEAN="make KVER=${kernelver} clean"
MAKE="make KVER=${kernelver}"
BUILT_MODULE_NAME[0]="OpticalDrv2"
BUILT_MODULE_LOCATION[0]=""
DEST_MODULE_LOCATION[0]="/extra"
BUILT_MODULE_NAME[1]="OpticalDrv4"
BUILT_MODULE_LOCATION[1]=""
DEST_MODULE_LOCATION[1]="/extra"
AUTOINSTALL="yes"
