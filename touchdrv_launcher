#!/bin/bash
set -euo pipefail

TYPE="${1:-}"

case "$TYPE" in
  touch2)
    BIN="/usr/bin/touch2/OpticalTouchServer.$(uname -m)"
    ;;
  touch4)
    BIN="/usr/bin/touch4/OpticalTouchServer.$(uname -m)"
    ;;
  *)
    echo "Unknown TYPE: $TYPE, exiting cleanly to prevent loop"
    exit 0
    ;;
esac

[ -x "$BIN" ] || exit 0
modprobe "OpticalDrv" || true
exec "$BIN"